{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/uploads/:path*",
      "destination": "/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads|assets|favicon.ico).*)*",
      "destination": "/index.html"
    }
  ]
}
